{% assign level = status.level | default: 'unknown' %}
<div class="layout layout--col gap">
  <div class="layout layout--row layout--between">
    <span class="title">KIP</span>
    <span class="label">{{ generated_at | date: "%l:%M %p" }}</span>
  </div>

  <div class="layout layout--row layout--between">
    <span class="value value--large">{{ status.label | upcase }}</span>
    <span class="label">{{ level }}</span>
  </div>

  <div class="divider"></div>

  <div class="layout layout--row layout--between">
    <span class="label">PI</span>
    {% if pi %}
      <span class="value">{{ pi.temperature_c | round: 0 }}°C · {{ pi.ram_used_gb | round: 1 }}/{{ pi.ram_total_gb | round: 1 }} GB</span>
    {% else %}
      <span class="value">unavailable</span>
    {% endif %}
  </div>

  <div class="layout layout--row layout--between">
    <span class="label">INTERNET</span>
    {% if internet %}
      <span class="value">↓{{ internet.download_mbps | round: 0 }} ↑{{ internet.upload_mbps | round: 0 }} Mbps</span>
    {% else %}
      <span class="value">unavailable</span>
    {% endif %}
  </div>

  <div class="layout layout--row layout--between">
    <span class="label">JOBS</span>
    {% if jobs %}
      <span class="value">{{ jobs.ok_30d }} OK · {{ jobs.recent_critical_failures.size }} critical</span>
    {% else %}
      <span class="value">unavailable</span>
    {% endif %}
  </div>

  <div class="layout layout--row layout--between">
    <span class="label">VOICE</span>
    {% if voice %}
      <span class="value">{{ voice.status | upcase }} · {{ voice.success_rate_30d | round: 0 }}%</span>
    {% else %}
      <span class="value">unavailable</span>
    {% endif %}
  </div>

  {% if status.notices.size > 0 %}
    <div class="divider"></div>
    {% for notice in status.notices limit: 2 %}
      <div class="label">{{ notice }}</div>
    {% endfor %}
  {% endif %}

  <div class="layout layout--row layout--between mt--auto">
    <span class="label">updated {{ generated_at | date: "%l:%M %p" }}</span>
    <span class="label">kip.computer</span>
  </div>
</div>
